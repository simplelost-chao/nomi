# Nomi 后端环境变量示例 —— 复制为仓库根目录的 .env 并填入你自己的值
# 所有变量以 NOMI_ 为前缀。切勿把真实密钥提交到仓库！

# ── 数据库 ──
# 云端：PostgreSQL（需 pgvector 扩展）
NOMI_DATABASE_URL=postgresql+asyncpg://nomi:nomi@localhost:5432/nomi?ssl=disable
# 桌面单机：改用 SQLite
# NOMI_DATABASE_URL=sqlite+aiosqlite:///~/.nomi/nomi.db

# ── Redis（可选，桌面模式不需要）──
NOMI_REDIS_URL=redis://localhost:6380/0

# ── LLM 提供方：claude-cli / anthropic / openai ──
NOMI_LLM_PROVIDER=claude-cli

# ── 各家 API Key（按需填写）──
NOMI_ANTHROPIC_API_KEY=
NOMI_OPENAI_API_KEY=
NOMI_DEEPSEEK_API_KEY=
NOMI_GEMINI_API_KEY=

# ── 向量维度（与嵌入模型一致）──
NOMI_EMBEDDING_DIMENSIONS=768

# Tool skills（工具技能）
NOMI_AMAP_API_KEY=        # 高德开放平台 Web 服务 Key：https://console.amap.com/dev/key/app
NOMI_DEFAULT_CITY=北京     # 美食/路线/天气的默认城市
