{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "rootDir": "src/renderer",
    "baseUrl": "src/renderer",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/renderer"]
}
